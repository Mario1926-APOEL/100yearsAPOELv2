    const dateBadge=single
      ? `<div class="dt"><div class="seg single"><span class="mo">${m1}</span><span class="da">${e.d}</span></div></div>`
      : `<div class="dt"><div class="seg"><span class="mo">${m1}</span><span class="da">${e.d}</span></div><span class="dash">–</span><div class="seg"><span class="mo">${m2}</span><span class="da">${e.d2}</span></div></div>`;
    return `
    <div class="lrow" data-event="${i}" role="button" tabindex="0">
      <div class="bg" style="background-image:url('./${e.img}.jpg')"></div>
      ${dateBadge}
      <span class="status">${L(e,'status')||(LANG==='el'?'Ανακοινώθηκε':'Announced')}</span>
      <div class="ti"><h3>${L(e,'t')}</h3><p>${L(e,'p')}</p></div>
      <button class="ticket" type="button">${L(e,'cta')||(LANG==='el'?'Πληροφορίες':'Info')}</button>
    </div>`;}).join('');
  }
  renderLedger();

  /* ---- EVENT MODAL ---- */
  const em=document.getElementById('eventModal'),emBody=document.getElementById('emBody');
  function openEvent(i){
    const e=events[i];if(!e)return;
    const L=(o,k)=>LANG==='en'&&o[k+'_en']?o[k+'_en']:o[k];
    const lbl=LANG==='el'?['Ημερομηνία','Ώρα','Τόπος']:['Date','Time','Venue'];
    const info=(LANG==='en'&&e.info_en?e.info_en:e.info);
    emBody.innerHTML=`
      <div class="em-date"><span class="em-day">${e.d}</span><span class="em-mon">${L(e,'m')}</span></div>
      <h3 class="em-title">${L(e,'t')}</h3>
      <div class="em-rows">
        <div class="em-row"><span class="em-k">${lbl[0]}</span><span class="em-v">${L(e,'full')}</span></div>
        <div class="em-row"><span class="em-k">${lbl[1]}</span><span class="em-v">${L(e,'time')}</span></div>
        <div class="em-row"><span class="em-k">${lbl[2]}</span><span class="em-v">${L(e,'venue')}</span></div>
      </div>
      <p class="em-desc">${L(e,'desc')}</p>
      <ul class="em-list">${info.map(x=>`<li>${x}</li>`).join('')}</ul>`;
    em.classList.add('open');document.body.style.overflow='hidden';
  }
  function closeEvent(){em.classList.remove('open');document.body.style.overflow='';}
  document.getElementById('ledger').addEventListener('click',e=>{const r=e.target.closest('[data-event]');if(r)openEvent(+r.dataset.event);});
  document.getElementById('ledger').addEventListener('keydown',e=>{if((e.key==='Enter'||e.key===' ')&&e.target.closest('[data-event]')){e.preventDefault();openEvent(+e.target.closest('[data-event]').dataset.event);}});
  document.getElementById('emClose').onclick=closeEvent;
  em.addEventListener('click',e=>{if(e.target===em)closeEvent();});
  addEventListener('keydown',e=>{if(e.key==='Escape'&&em.classList.contains('open'))closeEvent();});

  /* ---- STORIES ---- */
  const stories=[{who:'Ανδρέας',txt:'Πήγα στο πρώτο μου παιχνίδι με τον παππού μου το 1996. Δεν ξέχασα ποτέ εκείνη την ατμόσφαιρα στις εξέδρες.',seed:true}];
  const wall=document.getElementById('wall');
  const esc=t=>t.replace(/[&<>]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;'}[c]));
  function render(){
    wall.innerHTML=stories.length?stories.map(s=>`
    <div class="post"><div class="who"><span class="quote">“</span>${esc(s.who)}</div>
    <div class="txt">${esc(s.txt)}</div></div>`).join('')
    :`<div class="empty">${LANG==='el'?'Γίνετε ο πρώτος που θα γράψει στον τοίχο του αιώνα.':'Be the first to write on the wall of the century.'}</div>`;}
  document.getElementById('postBtn').addEventListener('click',()=>{
    const n=document.getElementById('name').value.trim()||(LANG==='el'?'Φίλαθλος':'Fan');
    const t=document.getElementById('text').value.trim();
    if(!t){document.getElementById('text').focus();return;}
    stories.unshift({who:n,txt:t});
    document.getElementById('name').value='';document.getElementById('text').value='';render();});
  render();

  /* ---- Gold particle field ---- */
  const cv=document.getElementById('goldCanvas'),cx=cv.getContext('2d');
  let W,H,parts=[],mouse={x:-999,y:-999};
  function resize(){W=cv.width=cv.offsetWidth;H=cv.height=cv.offsetHeight;init();}
  function init(){parts=[];const n=Math.min(110,Math.floor(W*H/14000));
    for(let i=0;i<n;i++)parts.push({x:Math.random()*W,y:Math.random()*H,vx:(Math.random()-.5)*.25,vy:(Math.random()-.5)*.25,r:Math.random()*1.8+.4,a:Math.random()*.5+.2,gold:Math.random()<.28});}
  function draw(){cx.clearRect(0,0,W,H);
    for(const p of parts){p.x+=p.vx;p.y+=p.vy;if(p.x<0||p.x>W)p.vx*=-1;if(p.y<0||p.y>H)p.vy*=-1;
      const dx=mouse.x-p.x,dy=mouse.y-p.y,d=Math.hypot(dx,dy);
      if(d<140){const f=(140-d)/140*0.6;p.x+=dx/d*f;p.y+=dy/d*f;}
      cx.beginPath();cx.arc(p.x,p.y,p.r,0,7);cx.fillStyle=p.gold?`rgba(224,181,58,${p.a})`:`rgba(63,160,224,${p.a})`;cx.fill();}
    for(let i=0;i<parts.length;i++)for(let j=i+1;j<parts.length;j++){const a=parts[i],b=parts[j],dd=Math.hypot(a.x-b.x,a.y-b.y);
      if(dd<96){cx.strokeStyle=`rgba(63,160,224,${(1-dd/96)*.14})`;cx.lineWidth=.6;cx.beginPath();cx.moveTo(a.x,a.y);cx.lineTo(b.x,b.y);cx.stroke();}}
    requestAnimationFrame(draw);}
  addEventListener('resize',resize);
  cv.addEventListener('mousemove',e=>{const r=cv.getBoundingClientRect();mouse.x=e.clientX-r.left;mouse.y=e.clientY-r.top;});
  cv.addEventListener('mouseleave',()=>{mouse.x=mouse.y=-999;});
  cv.addEventListener('touchmove',e=>{const r=cv.getBoundingClientRect(),t=e.touches[0];mouse.x=t.clientX-r.left;mouse.y=t.clientY-r.top;},{passive:true});
  resize();if(!reduce)draw();

  const mega=document.getElementById('mega');
  if(mega&&!reduce)addEventListener('mousemove',e=>{const rx=(e.clientY/innerHeight-.5)*-8,ry=(e.clientX/innerWidth-.5)*10;
    mega.style.transform=`perspective(800px) rotateX(${rx}deg) rotateY(${ry}deg)`;});

  /* ---- Tabs + reveal ---- */
  const btns=document.querySelectorAll('nav button'),panels=document.querySelectorAll('.panel');
  const io=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting)e.target.classList.add('in')}),{threshold:.12});
  function obs(){document.querySelectorAll('.panel.active .reveal').forEach(r=>io.observe(r));}
  document.querySelectorAll('[data-jump]').forEach(a=>a.addEventListener('click',e=>{e.preventDefault();const b=document.querySelector(`nav button[data-tab="${a.dataset.jump}"]`);if(b)b.click();}));
  btns.forEach(b=>b.addEventListener('click',()=>{
    btns.forEach(x=>x.classList.remove('active'));panels.forEach(p=>p.classList.remove('active'));
    b.classList.add('active');document.getElementById(b.dataset.tab).classList.add('active');
    document.querySelectorAll('.reveal').forEach(r=>r.classList.remove('in'));
    window.scrollTo({top:document.querySelector('nav').offsetTop,behavior:'smooth'});setTimeout(obs,60);}));
  obs();

  /* ---- LANGUAGE SWITCH ---- */
  function setLang(l){
    if(l===LANG)return;
    LANG=l;
    document.documentElement.lang=l;
    // toggle button state
    document.querySelectorAll('.lang button').forEach(b=>b.classList.toggle('on',b.dataset.lang===l));
    // swap static texts
    document.querySelectorAll('[data-el]').forEach(el=>{el.textContent=el.getAttribute(l==='en'?'data-en':'data-el');});
    document.querySelectorAll('[data-ph-el]').forEach(el=>{el.setAttribute('placeholder',el.getAttribute(l==='en'?'data-ph-en':'data-ph-el'));});
    // aria labels for lightbox/modal
    const A=(id,el_,en_)=>{const x=document.getElementById(id);if(x)x.setAttribute('aria-label',l==='en'?en_:el_);};
    A('lbx','Κλείσιμο','Close');A('lbPrev','Προηγούμενη','Previous');A('lbNext','Επόμενη','Next');A('emClose','Κλείσιμο','Close');
    // re-run dynamic renders
    renderGtools();drawGallery(curDecade);renderHistory();renderDepts();renderNextEvent();renderLedger();render();
    // keep active gallery chip highlighted
    document.querySelectorAll('.gchip').forEach(c=>c.classList.toggle('on',c.dataset.d===curDecade));
  }
  document.querySelectorAll('.lang button').forEach(b=>b.addEventListener('click',()=>setLang(b.dataset.lang)));

  /* ---- REVEAL COUNTDOWN (until 26/07/2026) ---- */
  (function(){
    const target=new Date('2026-07-26T19:26:00+03:00');
    const elD=document.getElementById('rcd-d'),elH=document.getElementById('rcd-h'),
          elM=document.getElementById('rcd-m'),elS=document.getElementById('rcd-s');
    if(!elD)return;
    function tick(){
      const diff=target-new Date();
      if(diff<=0){
        const box=document.getElementById('revealCd');
        if(box)box.innerHTML='<div class="cd"><b>'+(LANG==='en'?'Revealed!':'Αποκαλύφθηκε!')+'</b></div>';
        clearInterval(t);return;
      }
      elD.textContent=Math.floor(diff/86400000);
      elH.textContent=Math.floor(diff/3600000)%24;
      elM.textContent=Math.floor(diff/60000)%60;
      elS.textContent=Math.floor(diff/1000)%60;
    }
    tick();const t=setInterval(tick,1000);
  })();
</script>
</body>
</html>
