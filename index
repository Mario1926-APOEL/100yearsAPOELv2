  let cdTimer=null;
  function renderNextEvent(){
    const box=document.getElementById('nextEvent');
    const now=new Date();
    const upcoming=events.map(e=>({...e,date:new Date(e.iso)})).filter(e=>e.date>now).sort((a,b)=>a.date-b.date)[0];
    const featured=upcoming||events[events.length-1];
    const L=(o,k)=>LANG==='en'&&o[k+'_en']?o[k+'_en']:o[k];
    const cdL=LANG==='el'?['Ημέρες','Ώρες','Λεπτά','Δευτ.']:['Days','Hours','Min','Sec'];
    const kLabel=upcoming?(LANG==='el'?'Επόμενη εκδήλωση':'Next event'):(LANG==='el'?'Πρόγραμμα εορτασμών':'Anniversary programme');
    box.innerHTML=`<div><div class="next-k">${kLabel}</div>
      <div class="next-title">${L(featured,'t')}</div><div class="next-meta">${L(featured,'full')} · ${L(featured,'time')} · ${L(featured,'venue')}</div></div>
      <div class="countdown" id="countdown"><div class="cd-box"><b>—</b><span>${cdL[0]}</span></div><div class="cd-box"><b>—</b><span>${cdL[1]}</span></div><div class="cd-box"><b>—</b><span>${cdL[2]}</span></div><div class="cd-box"><b>—</b><span>${cdL[3]}</span></div></div>`;
    if(cdTimer){clearInterval(cdTimer);cdTimer=null;}
    if(!upcoming)return;
    const tick=()=>{
      const diff=Math.max(0,featured.date-new Date());
      const d=Math.floor(diff/86400000),h=Math.floor(diff/3600000)%24,m=Math.floor(diff/60000)%60,sec=Math.floor(diff/1000)%60;
      const cd=document.getElementById('countdown');if(!cd)return;
      cd.innerHTML=`<div class="cd-box"><b>${d}</b><span>${cdL[0]}</span></div><div class="cd-box"><b>${h}</b><span>${cdL[1]}</span></div><div class="cd-box"><b>${m}</b><span>${cdL[2]}</span></div><div class="cd-box"><b>${sec}</b><span>${cdL[3]}</span></div>`;
    };
    tick();cdTimer=setInterval(tick,1000);
  }
