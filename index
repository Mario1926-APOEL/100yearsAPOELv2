<!DOCTYPE html>
<html lang="el">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ΑΠΟΕΛ · ΕΝΑΣ ΑΙΩΝΑΣ · 1926–2026</title>
<style>
  :root{
    /* ΑΠΟΕΛ 100 ΧΡΟΝΙΑ badge palette — navy field, sky-blue shield, gold laurel */
    --bg:#001b35;            /* badge navy background */
    --bg2:#06294a;           /* deeper panel navy */
    --navy-deep:#001327;
    --blue:#1f7fc4;          /* shield sky blue */
    --blue-bright:#3fa0e0;
    --blue-deep:#0c4a7a;
    /* the variable names below are reused everywhere as "accent" — repurposed to the badge gold */
    --gold:#e0b53a;          /* laurel gold */
    --gold-bright:#f6d873;   /* bright gold highlight */
    --gold-deep:#a07d1f;     /* deep gold */
    --gold-dim:rgba(224,181,58,.32);
    --ash:#cdd9e6;           /* soft blue-white text */
    --hair:rgba(224,181,58,.18);
    --hair-blue:rgba(63,160,224,.22);
  }
  *{box-sizing:border-box;margin:0;padding:0}
  html{scroll-behavior:smooth}
  body{background:var(--bg);color:var(--ash);overflow-x:hidden;
    font-family:"Helvetica Neue",Arial,sans-serif;line-height:1.6;-webkit-font-smoothing:antialiased;}
  body::before{content:"";position:fixed;inset:0;pointer-events:none;z-index:1;
    background:radial-gradient(120% 90% at 50% 0%,rgba(31,127,196,.10) 0%,transparent 42%,rgba(0,12,26,.78) 100%);mix-blend-mode:normal;}
  .serif{font-family:"Bodoni MT","Didot",Georgia,serif;}

  /* HERO */
  #hero{position:relative;height:100vh;min-height:620px;display:flex;flex-direction:column;
    align-items:center;justify-content:center;text-align:center;overflow:hidden;}
  #goldCanvas{position:absolute;inset:0;width:100%;height:100%;z-index:0;}
  .hero-inner{position:relative;z-index:3;mix-blend-mode:screen;}
  .eyebrow{letter-spacing:.6em;font-size:.66rem;text-transform:uppercase;color:var(--gold);
    margin-bottom:1.4em;opacity:0;animation:rise 1.1s .2s forwards;}
  .mega{font-family:"Bodoni MT","Didot",Georgia,serif;font-weight:700;font-size:clamp(7rem,32vw,22rem);
    line-height:.82;letter-spacing:-.02em;background:linear-gradient(180deg,var(--gold-bright),var(--gold) 40%,var(--blue) 70%,var(--blue-deep));
    -webkit-background-clip:text;background-clip:text;color:transparent;
    filter:drop-shadow(0 2px 30px rgba(63,160,224,.45));opacity:0;animation:rise 1.2s .35s forwards;cursor:default;user-select:none;}
  .hero-badge{width:clamp(220px,34vw,420px);height:auto;margin:0 auto 1.6em;display:block;
    filter:drop-shadow(0 14px 50px rgba(0,0,0,.6)) drop-shadow(0 0 36px rgba(63,160,224,.32));
    opacity:0;animation:rise 1.3s .1s forwards;}
  /* REVEAL PLACEHOLDER (until 26/07/2026) */
  .logo-reveal{position:relative;width:clamp(240px,40vw,420px);aspect-ratio:1/1;margin:0 auto 1.6em;
    display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;
    border-radius:50%;
    background:radial-gradient(circle at 50% 40%,rgba(31,127,196,.18),rgba(0,19,39,.6) 70%);
    box-shadow:0 14px 50px rgba(0,0,0,.55),inset 0 0 40px rgba(63,160,224,.12);
    opacity:0;animation:rise 1.3s .1s forwards;}
  .logo-reveal::after{content:"";position:absolute;inset:-2px;border-radius:50%;
    border:2px dashed var(--gold-deep);pointer-events:none;
    animation:spinDash 84s linear infinite;}
  @keyframes spinDash{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
  .logo-reveal::before{content:"";position:absolute;inset:14px;border-radius:50%;border:1px solid var(--hair);pointer-events:none;}
  .logo-reveal .r-100{font-family:"Bodoni MT","Didot",Georgia,serif;font-weight:700;
    font-size:clamp(3.4rem,11vw,6rem);line-height:.9;
    background:linear-gradient(180deg,var(--gold-bright),var(--gold) 55%,var(--gold-deep));
    -webkit-background-clip:text;background-clip:text;color:transparent;}
  .logo-reveal .r-years{font-size:clamp(.55rem,2.4vw,.78rem);letter-spacing:.34em;text-transform:uppercase;color:var(--ash);margin-top:.2em;}
  .logo-reveal .r-soon{margin-top:1.1em;font-size:clamp(.52rem,2.2vw,.68rem);letter-spacing:.26em;text-transform:uppercase;color:var(--blue-bright);}
  .logo-reveal .r-date{margin-top:.5em;font-family:"Bodoni MT","Didot",Georgia,serif;font-style:italic;
    font-size:clamp(1.1rem,4.5vw,1.7rem);color:var(--gold-bright);letter-spacing:.04em;}
  .logo-reveal .r-cd{display:flex;gap:clamp(8px,2.4vw,16px);margin-top:1em;}
  .logo-reveal .r-cd .cd{display:flex;flex-direction:column;align-items:center;line-height:1;}
  .logo-reveal .r-cd .cd b{font-family:"Bodoni MT","Didot",Georgia,serif;font-weight:700;
    font-size:clamp(1.2rem,5vw,2rem);color:#fff;}
  .logo-reveal .r-cd .cd span{font-size:clamp(.4rem,1.8vw,.55rem);letter-spacing:.18em;text-transform:uppercase;color:var(--gold-deep);margin-top:.3em;}
  .mega-sub{display:block;font-family:"Helvetica Neue",sans-serif;font-weight:300;font-size:clamp(.9rem,3vw,1.4rem);
    letter-spacing:.5em;color:var(--ash);-webkit-text-fill-color:var(--ash);margin-top:.6em;text-transform:uppercase;}
  .club-line{margin-top:1.8em;font-size:clamp(1rem,4vw,1.6rem);letter-spacing:.35em;color:var(--blue-bright);opacity:0;animation:rise 1.2s .55s forwards;}
  .span-years{margin-top:.8em;font-size:.85rem;letter-spacing:.5em;color:var(--ash);opacity:0;animation:rise 1.2s .75s forwards;}
  .scroll-hint{position:absolute;bottom:30px;left:50%;transform:translateX(-50%);z-index:3;
    font-size:.6rem;letter-spacing:.4em;color:var(--gold-dim);text-transform:uppercase;
    opacity:0;animation:rise 1s 1.3s forwards,bob 2.4s 2s infinite;}

  .hero-actions{margin-top:2.4em;display:flex;gap:14px;justify-content:center;flex-wrap:wrap;opacity:0;animation:rise 1.2s .95s forwards;}
  .hero-btn{border:1px solid var(--gold);color:var(--gold-bright);background:rgba(7,7,7,.35);
    text-decoration:none;font-size:.72rem;font-weight:700;letter-spacing:.26em;text-transform:uppercase;
    padding:15px 24px;transition:background .35s,color .35s,border-color .35s;backdrop-filter:blur(6px);}
  .hero-btn:hover{background:var(--gold);color:#070707;border-color:var(--gold-bright)}
  .hero-btn.secondary{border-color:var(--hair);color:var(--ash)}
  .hero-btn.secondary:hover{color:#070707;background:var(--gold-bright)}

  .next-event{border:1px solid var(--hair);background:linear-gradient(160deg,var(--bg2),var(--navy-deep));
    margin-bottom:34px;padding:28px 30px;display:grid;grid-template-columns:1.25fr 1fr;gap:24px;align-items:center;
    position:relative;overflow:hidden;}
  .next-event::before{content:"";position:absolute;inset:0 0 auto 0;height:3px;background:linear-gradient(90deg,var(--gold-deep),var(--gold-bright),var(--gold-deep));}
  .next-k{font-size:.66rem;letter-spacing:.28em;text-transform:uppercase;color:var(--gold-deep);margin-bottom:8px;}
  .next-title{font-family:"Bodoni MT","Didot",Georgia,serif;color:var(--gold-bright);font-size:clamp(1.7rem,4vw,2.8rem);line-height:1.05;}
  .next-meta{color:var(--ash);margin-top:10px;font-weight:300;}
  .countdown{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;}
  .cd-box{border:1px solid var(--hair);padding:16px 10px;text-align:center;background:rgba(212,175,55,.04);}
  .cd-box b{display:block;font-family:"Bodoni MT",serif;color:var(--gold-bright);font-size:2rem;line-height:1;}
  .cd-box span{display:block;margin-top:7px;font-size:.58rem;letter-spacing:.18em;text-transform:uppercase;color:var(--gold-deep);}
  .event-status{display:inline-block;margin-bottom:12px;border:1px solid var(--gold-deep);color:var(--gold-bright);
    padding:5px 9px;font-size:.56rem;letter-spacing:.16em;text-transform:uppercase;}
  @media(max-width:760px){.next-event{grid-template-columns:1fr}.countdown{grid-template-columns:repeat(2,1fr)}}

  @keyframes rise{from{opacity:0;transform:translateY(28px)}to{opacity:1;transform:none}}
  @keyframes bob{0%,100%{transform:translateX(-50%) translateY(0)}50%{transform:translateX(-50%) translateY(8px)}}

  /* NAV */
  nav{position:sticky;top:0;z-index:40;display:flex;justify-content:center;flex-wrap:wrap;
    background:rgba(7,7,7,.82);backdrop-filter:blur(12px);border-top:1px solid var(--hair);border-bottom:1px solid var(--hair);}
  nav button{background:none;border:none;color:var(--ash);cursor:pointer;font-family:inherit;font-size:.72rem;
    font-weight:600;letter-spacing:.28em;text-transform:uppercase;padding:20px 22px;position:relative;transition:color .35s;}
  nav button:hover{color:var(--gold-bright)}
  nav button.active{color:var(--gold-bright)}
  nav button.active::after{content:"";position:absolute;left:22px;right:22px;bottom:12px;height:1px;
    background:linear-gradient(90deg,transparent,var(--gold-bright),transparent);}
  nav button:focus-visible{outline:1px solid var(--gold);outline-offset:-6px;}

  /* PANELS */
  main{position:relative;z-index:2;max-width:1100px;margin:0 auto;padding:80px 24px 120px;}
  .panel{display:none}
  .panel.active{display:block}
  .reveal{opacity:0;transform:translateY(30px);transition:opacity .9s cubic-bezier(.2,.7,.2,1),transform .9s cubic-bezier(.2,.7,.2,1);}
  .reveal.in{opacity:1;transform:none}
  .sec-head{margin-bottom:64px;}
  .sec-head .k{font-family:"Bodoni MT",serif;font-style:italic;color:var(--gold-deep);font-size:1.1rem;letter-spacing:.1em;}
  .sec-head h2{font-family:"Bodoni MT","Didot",Georgia,serif;font-weight:700;font-size:clamp(2.4rem,8vw,5rem);
    line-height:.95;letter-spacing:-.02em;margin-top:.1em;background:linear-gradient(180deg,var(--gold-bright),var(--gold) 55%,var(--gold-deep));
    -webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;}
  .sec-head .lead{max-width:560px;margin-top:18px;color:var(--ash);font-weight:300;}

  /* DEPARTMENTS / SPORTS */
  .depts-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;}
  .dept{position:relative;border:1px solid var(--hair);border-radius:4px;padding:28px 20px;
    background:linear-gradient(165deg,var(--bg2),var(--navy-deep));text-align:center;
    transition:transform .35s,border-color .35s,box-shadow .35s;overflow:hidden;}
  .dept::after{content:"";position:absolute;left:0;right:0;top:0;height:3px;
    background:linear-gradient(90deg,var(--gold-deep),var(--gold-bright),var(--gold-deep));
    transform:scaleX(0);transform-origin:left;transition:transform .4s;}
  .dept:hover{transform:translateY(-5px);border-color:var(--gold);box-shadow:0 16px 40px rgba(0,0,0,.45);}
  .dept:hover::after{transform:scaleX(1);}
  .dept-mark{display:block;width:34px;height:3px;margin:0 auto 16px;border-radius:2px;
    background:linear-gradient(90deg,var(--gold-deep),var(--gold-bright),var(--gold-deep));}
  .dept h3{color:var(--gold-bright);font-size:1.05rem;font-weight:600;letter-spacing:.02em;margin-bottom:6px;}
  .dept-titles{display:flex;justify-content:center;gap:14px;margin-top:18px;padding-top:16px;
    border-top:1px solid var(--hair);flex-wrap:wrap;}
  .dt-badge{display:flex;flex-direction:column;align-items:center;line-height:1;}
  .dt-badge b{font-family:"Bodoni MT","Didot",Georgia,serif;font-weight:700;font-size:1.7rem;color:var(--gold-bright);}
  .dt-badge span{font-size:.56rem;letter-spacing:.1em;text-transform:uppercase;color:var(--gold-deep);margin-top:5px;}
  .dept-active{margin-top:18px;padding-top:16px;border-top:1px solid var(--hair);
    font-size:.62rem;letter-spacing:.18em;text-transform:uppercase;color:var(--blue-bright);}
  .titles-total{display:flex;flex-direction:column;align-items:center;justify-content:center;
    text-align:center;padding:34px 20px;margin-bottom:20px;border:1px solid var(--gold-deep);border-radius:4px;
    background:linear-gradient(165deg,rgba(224,181,58,.08),var(--navy-deep));position:relative;overflow:hidden;}
  .titles-total::before{content:"";position:absolute;left:0;right:0;top:0;height:3px;
    background:linear-gradient(90deg,var(--gold-deep),var(--gold-bright),var(--gold-deep));}
  .titles-total .tt-num{font-family:"Bodoni MT","Didot",Georgia,serif;font-weight:700;
    font-size:clamp(3rem,9vw,5rem);line-height:1;
    background:linear-gradient(180deg,var(--gold-bright),var(--gold) 55%,var(--gold-deep));
    -webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;}
  .titles-total .tt-label{font-size:.7rem;letter-spacing:.3em;text-transform:uppercase;color:var(--ash);margin-top:12px;}
  .dept-group-title{font-family:"Bodoni MT","Didot",Georgia,serif;font-style:italic;color:var(--gold-deep);
    font-size:1.2rem;letter-spacing:.06em;margin:42px 0 20px;}
  @media(max-width:880px){.depts-grid{grid-template-columns:repeat(2,1fr);}}
  @media(max-width:480px){.depts-grid{grid-template-columns:1fr;}}

  /* HISTORY — timeline with photos */
  .tl{position:relative;}
  .tl-row{display:grid;grid-template-columns:minmax(120px,160px) 220px 1fr;gap:26px;align-items:center;
    padding:30px 0;border-top:1px solid var(--hair);position:relative;}
  .tl-row:last-child{border-bottom:1px solid var(--hair);}
  .tl-year{font-family:"Bodoni MT","Didot",Georgia,serif;font-weight:700;font-size:clamp(2rem,6vw,3.4rem);
    line-height:1;color:transparent;-webkit-text-stroke:1px var(--blue);transition:color .5s,-webkit-text-stroke .5s;letter-spacing:-.02em;}
  .tl-row:hover .tl-year{color:var(--gold-bright);-webkit-text-stroke:1px var(--gold-bright);}
  .tl-thumb{aspect-ratio:4/3;border:1px solid var(--hair);overflow:hidden;background:var(--navy-deep);cursor:pointer;}
  .tl-thumb img{width:100%;height:100%;object-fit:cover;filter:grayscale(.35) contrast(1.03);transition:transform .6s,filter .6s;}
  .tl-thumb:hover img{transform:scale(1.06);filter:grayscale(0)}
  .tl-body h3{color:var(--gold);font-size:1.15rem;letter-spacing:.04em;font-weight:600;margin-bottom:6px;}
  .tl-body p{color:var(--ash);font-weight:300;max-width:520px;}

  /* GALLERY — mosaic of real photos */
  .gtools{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:26px;}
  .gchip{background:transparent;border:1px solid var(--hair);color:var(--ash);border-radius:30px;padding:8px 16px;
    font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;cursor:pointer;font-family:inherit;transition:.25s;}
  .gchip:hover{color:var(--gold-bright);border-color:var(--gold-deep)}
  .gchip.on{background:var(--gold);color:#070707;border-color:var(--gold);font-weight:600}
  .mosaic{column-count:3;column-gap:14px;}
  .frame{break-inside:avoid;margin-bottom:14px;border:1px solid var(--hair);position:relative;overflow:hidden;
    background:var(--navy-deep);cursor:pointer;transition:border-color .4s;}
  .frame:hover{border-color:var(--gold)}
  .frame img{width:100%;display:block;filter:grayscale(.3) contrast(1.02);transition:transform .6s,filter .6s;}
  .frame:hover img{transform:scale(1.04);filter:grayscale(0)}
  .frame figcaption{position:absolute;left:0;right:0;bottom:0;padding:26px 14px 12px;z-index:2;
    background:linear-gradient(transparent,rgba(0,0,0,.82));font-family:"Bodoni MT",serif;font-style:italic;
    color:var(--gold-bright);font-size:1.02rem;}
  .frame .yr{position:absolute;top:10px;left:14px;font-family:"Bodoni MT",serif;font-weight:700;
    color:var(--gold-bright);font-size:.9rem;letter-spacing:.05em;z-index:2;text-shadow:0 1px 4px rgba(0,0,0,.8);}

  /* LIGHTBOX */
  .lb{position:fixed;inset:0;z-index:90;background:rgba(5,5,4,.94);display:none;align-items:center;justify-content:center;padding:30px;}
  .lb.open{display:flex;animation:lbf .3s}
  @keyframes lbf{from{opacity:0}to{opacity:1}}
  .lb figure{max-width:1000px;width:100%;text-align:center;}
  .lb img{max-width:100%;max-height:78vh;border:1px solid var(--hair);box-shadow:0 20px 60px rgba(0,0,0,.6);}
  .lb figcaption{margin-top:16px;font-family:"Bodoni MT",serif;font-style:italic;color:var(--gold-bright);font-size:1.2rem;}
  .lb .lbyr{color:var(--gold-deep);font-style:normal;letter-spacing:.2em;font-size:.8rem;margin-right:.8em;}
  .lb-x{position:fixed;top:22px;right:28px;background:none;border:none;color:var(--ash);font-size:1.8rem;cursor:pointer;z-index:91;}
  .lb-x:hover{color:var(--gold-bright)}
  .lb-nav{position:fixed;top:50%;transform:translateY(-50%);background:none;border:1px solid var(--hair);color:var(--gold-bright);
    width:48px;height:48px;border-radius:50%;font-size:1.4rem;cursor:pointer;z-index:91;transition:.25s;}
  .lb-nav:hover{background:var(--gold);color:#070707;border-color:var(--gold)}
  #lbPrev{left:24px} #lbNext{right:24px}

  /* EVENTS — vertical cards grid */
  .ledger{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;}
  .lrow{display:flex;flex-direction:column;justify-content:flex-end;position:relative;overflow:hidden;
    cursor:pointer;min-height:440px;border:1px solid var(--hair);
    background:linear-gradient(165deg,var(--bg2),var(--navy-deep));
    transition:transform .4s,box-shadow .4s,border-color .4s;}
  .lrow:hover,.lrow:focus-visible{transform:translateY(-6px);border-color:var(--gold);
    box-shadow:0 18px 50px rgba(0,0,0,.5),0 0 30px rgba(63,160,224,.18);}
  .lrow:focus-visible{outline:none;}
  /* background image fills the upper portion, fading into the card */
  .lrow .bg{position:absolute;inset:0 0 38% 0;background-size:cover;background-position:center;
    filter:grayscale(.55) contrast(1.05) brightness(.9);transition:filter .6s,transform .6s;}
  .lrow:hover .bg{filter:grayscale(0) contrast(1.05) brightness(.95);transform:scale(1.05);}
  .lrow::after{content:"";position:absolute;inset:0;pointer-events:none;
    background:linear-gradient(to bottom,rgba(0,12,26,.05) 0%,rgba(0,12,26,.35) 45%,rgba(6,41,74,.96) 72%,var(--navy-deep) 100%);}
  /* date badge top-left */
  .lrow .dt{position:absolute;top:0;left:0;z-index:3;display:flex;gap:14px;
    background:linear-gradient(135deg,var(--gold-bright),var(--gold));padding:12px 18px 14px;
    border-bottom-right-radius:4px;box-shadow:0 6px 18px rgba(0,0,0,.4);}
  .lrow .dt .seg{display:flex;flex-direction:column;align-items:center;line-height:1;position:relative;}
  .lrow .dt .seg .mo{font-size:.56rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--navy-deep);margin-bottom:3px;opacity:.85;}
  .lrow .dt .seg .da{font-family:"Bodoni MT","Didot",Georgia,serif;font-weight:700;font-size:2.1rem;color:var(--navy-deep);}
  .lrow .dt .dash{align-self:center;color:var(--navy-deep);font-weight:700;opacity:.6;margin-top:6px;}
  .lrow .dt .seg.single+.dash,.lrow .dt .seg.single~.dash{display:none;}
  /* content */
  .lrow .ti{position:relative;z-index:3;padding:0 22px;}
  .lrow .ti h3{color:#fff;font-size:1.18rem;font-weight:700;letter-spacing:.01em;line-height:1.25;margin-bottom:4px;
    text-shadow:0 1px 8px rgba(0,0,0,.6);}
  .lrow .ti p{color:var(--ash);font-weight:300;font-size:.86rem;}
  .lrow .status{position:relative;z-index:3;margin:14px 22px 0;align-self:flex-start;
    border:1px solid var(--gold-deep);color:var(--gold-bright);background:rgba(0,12,26,.4);
    padding:4px 10px;font-size:.54rem;letter-spacing:.16em;text-transform:uppercase;}
  .lrow .ticket{position:relative;z-index:3;margin:16px 22px 22px;display:block;text-align:center;
    background:linear-gradient(135deg,var(--gold-bright),var(--gold));color:var(--navy-deep);
    text-decoration:none;font-size:.72rem;font-weight:800;letter-spacing:.18em;text-transform:uppercase;
    padding:14px 12px;border:none;cursor:pointer;font-family:inherit;
    transition:transform .3s,box-shadow .3s,filter .3s;}
  .lrow .ticket:hover{filter:brightness(1.08);box-shadow:0 8px 22px rgba(224,181,58,.35);transform:translateY(-2px);}
  .lrow .presale{position:relative;z-index:3;margin:-6px 22px 18px;font-size:.7rem;color:var(--gold-bright);
    letter-spacing:.04em;}
  @media(max-width:920px){.ledger{grid-template-columns:repeat(2,1fr);}}
  @media(max-width:520px){.ledger{grid-template-columns:1fr;}.lrow{min-height:380px;}}

  /* EVENT MODAL */
  .em{position:fixed;inset:0;z-index:95;background:rgba(5,5,4,.9);backdrop-filter:blur(6px);
    display:none;align-items:center;justify-content:center;padding:24px;}
  .em.open{display:flex;animation:emf .3s;}
  @keyframes emf{from{opacity:0}to{opacity:1}}
  .em-box{position:relative;max-width:540px;width:100%;background:linear-gradient(160deg,var(--bg2),var(--navy-deep));
    border:1px solid var(--hair);padding:42px 38px 38px;max-height:88vh;overflow-y:auto;
    box-shadow:0 30px 80px rgba(0,0,0,.6);animation:emrise .4s cubic-bezier(.2,.7,.2,1);}
  @keyframes emrise{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:none}}
  .em-close{position:absolute;top:16px;right:18px;background:none;border:none;color:var(--ash);
    font-size:1.4rem;cursor:pointer;transition:color .25s;}
